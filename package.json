  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
